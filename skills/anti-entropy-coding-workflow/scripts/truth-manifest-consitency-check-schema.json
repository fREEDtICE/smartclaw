{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/consistency-check.schema.json",
  "title": "Consistency Check Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["consistency_check"],
  "properties": {
    "consistency_check": {
      "$ref": "#/$defs/consistencyCheck"
    }
  },
  "$defs": {
    "artifactType": {
      "type": "string",
      "enum": [
        "system-overview",
        "invariant-spec",
        "api-contract",
        "interface-contract",
        "e2e-spec",
        "test-environment",
        "architecture-boundary",
        "state-machine",
        "lifecycle-spec",
        "risk-zone",
        "supplemental"
      ]
    },
    "checkStatus": {
      "type": "string",
      "enum": ["pass", "warning", "fail"]
    },
    "conflictKind": {
      "type": "string",
      "enum": [
        "type-mismatch",
        "authority-mismatch",
        "semantic-conflict",
        "missing-supporting-contract",
        "scope-overlap",
        "other"
      ]
    },
    "findingKind": {
      "type": "string",
      "enum": [
        "coverage-gap",
        "unsupported-assumption",
        "stale-document",
        "redundancy",
        "other"
      ]
    },
    "checkedManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "timestamp"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "被检查的 manifest 文件路径"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "被检查的 manifest 生成时间"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_point_count",
        "conflict_count",
        "other_finding_count"
      ],
      "properties": {
        "missing_point_count": {
          "type": "integer",
          "minimum": 0
        },
        "conflict_count": {
          "type": "integer",
          "minimum": 0
        },
        "other_finding_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "section": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/artifactType"
        }
      }
    },
    "missingPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "description", "required_by"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required_by": {
          "type": "string",
          "minLength": 1
        },
        "related_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        }
      }
    },
    "conflictFound": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope",
        "severity",
        "confidence",
        "conflict_kind",
        "description",
        "related_artifacts",
        "recommended_next_action"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0
        },
        "conflict_kind": {
          "$ref": "#/$defs/conflictKind"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "related_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "description": "Artifacts in tension"
        },
        "recommended_next_action": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "otherUsefulFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_kind", "description"],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/findingKind"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "related_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        }
      }
    },
    "consistencyCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked_at",
        "scope",
        "status",
        "report_summary",
        "missing_points",
        "conflicts_found",
        "other_useful_findings"
      ],
      "properties": {
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/checkStatus"
        },
        "checked_manifest": {
          "$ref": "#/$defs/checkedManifest"
        },
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "report_summary": {
          "type": "string",
          "minLength": 1
        },
        "missing_points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/missingPoint"
          }
        },
        "conflicts_found": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/conflictFound"
          }
        },
        "other_useful_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/otherUsefulFinding"
          }
        }
      }
    }
  }
}
