{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/truth-manifest.schema.json",
  "title": "Truth Manifest Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_name",
    "generated_at",
    "truth_artifacts",
    "coverage_requirements",
    "change_log"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["2"]
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "truth_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/truthArtifact"
      }
    },
    "coverage_requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverageRequirement"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "change_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changeLogEntry"
      }
    }
  },
  "$defs": {
    "artifactType": {
      "type": "string",
      "enum": [
        "system-overview",
        "invariant-spec",
        "api-contract",
        "interface-contract",
        "e2e-spec",
        "test-environment",
        "architecture-boundary",
        "state-machine",
        "lifecycle-spec",
        "risk-zone",
        "supplemental"
      ]
    },
    "artifactAuthority": {
      "type": "string",
      "enum": [
        "required",
        "recommended",
        "informative"
      ]
    },
    "artifactFormat": {
      "type": "string",
      "enum": [
        "markdown",
        "yaml",
        "json",
        "openapi",
        "json-schema",
        "protobuf",
        "executable-test",
        "other"
      ]
    },
    "parserType": {
      "type": "string",
      "enum": [
        "markdown",
        "yaml",
        "json",
        "openapi",
        "json-schema",
        "playwright",
        "cucumber",
        "plain-text",
        "none"
      ]
    },
    "fingerprintAlgorithm": {
      "type": "string",
      "enum": [
        "sha256"
      ]
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "size"],
      "properties": {
        "algorithm": {
          "$ref": "#/$defs/fingerprintAlgorithm"
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "truthArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "path",
        "type",
        "authority",
        "format",
        "parser",
        "scope_tags",
        "coverage_ids",
        "owner",
        "last_reviewed_at",
        "fingerprint"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/artifactType"
        },
        "authority": {
          "$ref": "#/$defs/artifactAuthority"
        },
        "format": {
          "$ref": "#/$defs/artifactFormat"
        },
        "parser": {
          "$ref": "#/$defs/parserType"
        },
        "scope_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "coverage_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "last_reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "fingerprint": {
          "$ref": "#/$defs/fingerprint"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "authority": { "const": "required" }
            },
            "required": ["authority"]
          },
          "then": {
            "properties": {
              "type": {
                "enum": [
                  "system-overview",
                  "invariant-spec",
                  "api-contract",
                  "interface-contract",
                  "e2e-spec",
                  "test-environment"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authority": { "const": "recommended" }
            },
            "required": ["authority"]
          },
          "then": {
            "properties": {
              "type": {
                "enum": [
                  "architecture-boundary",
                  "state-machine",
                  "lifecycle-spec",
                  "risk-zone",
                  "supplemental"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "authority": { "const": "informative" }
            },
            "required": ["authority"]
          },
          "then": {
            "properties": {
              "type": {
                "enum": [
                  "supplemental"
                ]
              }
            }
          }
        }
      ]
    },
    "coverageRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "risk", "required_artifact_types"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "required_artifact_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactType"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "changeLogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "changes"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "changes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/changeItem"
          }
        }
      }
    },
    "changeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_kind", "path", "from", "to"],
      "properties": {
        "change_kind": {
          "type": "string",
          "enum": [
            "file-added",
            "file-removed",
            "fingerprint-updated",
            "type-changed",
            "authority-changed",
            "coverage-updated"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "change_kind": { "const": "file-added" }
            },
            "required": ["change_kind"]
          },
          "then": {
            "properties": {
              "from": { "const": "-" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "change_kind": { "const": "file-removed" }
            },
            "required": ["change_kind"]
          },
          "then": {
            "properties": {
              "to": { "const": "-" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "change_kind": { "const": "type-changed" }
            },
            "required": ["change_kind"]
          },
          "then": {
            "properties": {
              "from": { "$ref": "#/$defs/artifactType" },
              "to": { "$ref": "#/$defs/artifactType" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "change_kind": { "const": "authority-changed" }
            },
            "required": ["change_kind"]
          },
          "then": {
            "properties": {
              "from": { "$ref": "#/$defs/artifactAuthority" },
              "to": { "$ref": "#/$defs/artifactAuthority" }
            }
          }
        }
      ]
    }
  }
}
